# Set the default behavior, in case people don't have core.autocrlf set.
* text=auto

# Force these file types to always use LF (Line Feed) line endings.
# This prevents issues when editing on Windows and running on NixOS/Linux.
*.nix text eol=lf
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf
*.fish text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.conf text eol=lf
*.env text eol=lf

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
